# ── Ari intelligence engine ────────────────────────────────────────────────────
# Required. Powers all Ari responses via streaming GPT-4o.
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── NextAuth — required for all authenticated routes ────────────────────────────
# Full URL of your deployment. Must match exactly — NextAuth uses this for CSRF
# token validation. Mismatch = HTTP 409 on every sign-in attempt.
# Local:      NEXTAUTH_URL=http://localhost:3000
# Production: NEXTAUTH_URL=https://your-vercel-domain.vercel.app
# Note: On Vercel, NEXTAUTH_URL is auto-derived from VERCEL_URL if not set.
NEXTAUTH_URL=http://localhost:3000

# Random secret used to sign JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=replace-with-a-random-32-byte-hex-string

# Invite-only user list. JSON array of user objects.
# Generate bcrypt password hashes with:
#   node -e "require('bcryptjs').hash('yourpassword', 12).then(console.log)"
# Example (replace all values before deploying):
MAYA_USERS=[{"id":"u1","name":"Your Name","email":"you@example.com","password":"$2b$12$...bcrypt-hash-here...","org":"Your Org","role":"CEO"}]
