# ── OpenAI (MAYA intelligence engine) ───────────────────────────────────────────
# Required for the MAYA chat API route.
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── NextAuth ─────────────────────────────────────────────────────────────────────
# Full URL of your deployment. Must match exactly — mismatch causes HTTP 409.
# Local:      NEXTAUTH_URL=http://localhost:3000
# Production: NEXTAUTH_URL=https://your-vercel-domain.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Random secret for signing JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=replace-with-a-random-32-byte-hex-string

# ── MAYA user list (invite-only) ─────────────────────────────────────────────────
# JSON array. Generate bcrypt hashes with:
#   node -e "require('bcryptjs').hash('yourpassword', 12).then(console.log)"
MAYA_USERS=[{"id":"u1","name":"Your Name","email":"you@example.com","password":"$2b$12$...bcrypt-hash-here...","org":"Your Org","role":"CEO"}]

# ── Beta gate hardening (optional, recommended in production) ─────────────────────
# Comma-separated invite codes used by /api/beta-validate
# Example: BETA_INVITE_CODES=MAYA-EXEC-1A2B,MAYA-EXEC-3C4D
BETA_INVITE_CODES=
#
# Optional secret used to sign server-side beta access cookies. If omitted,
# MAYA falls back to existing server secrets.
BETA_GATE_SECRET=
#
# Set true to require a valid beta cookie for /api/chat requests.
# Keep false during transition if current users have not re-validated invite code yet.
ENFORCE_BETA_CHAT_GATE=false
